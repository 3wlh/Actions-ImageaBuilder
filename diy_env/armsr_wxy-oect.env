Model="OECT"
PROFILE="generic"

# 自定义所需安装的包列表
DIY_PACKAGES=""
DIY_PACKAGES="$DIY_PACKAGES luci-app-scriptrun luci-app-napcatapi luci-app-photopea"
Download "https://github.com/3wlh/OpenWrt_Packages/releases/download/GitHub-Actions_luci-app-photopea/luci-app-photopea_26.04.09-r222835_aarch64_generic.ipk"
DIY_PACKAGES="$DIY_PACKAGES docker dockerd docker-compose luci-i18n-dockerman-zh-cn"
DIY_PACKAGES="$DIY_PACKAGES luci-i18n-argon-config-zh-cn"
DIY_PACKAGES="$DIY_PACKAGES luci-i18n-hd-idle-zh-cn" #luci-i18n-uhttpd-zh-cn
DIY_PACKAGES="$DIY_PACKAGES luci-i18n-cloudflared-zh-cn"
DIY_PACKAGES="$DIY_PACKAGES luci-app-store"
DIY_PACKAGES="$DIY_PACKAGES luci-i18n-openlist2-zh-cn"
DIY_PACKAGES="$DIY_PACKAGES luci-app-unishare"
DIY_PACKAGES="$DIY_PACKAGES luci-app-sunpanel"

dir="$(pwd)/packages/diy_packages"
test -d ${dir} || mkdir -pm 755 ${dir}
function Download(){
	regexper='^(https?)://[a-zA-Z0-9.-]+\.[a-zA-Z0-9]{1,}(:[0-9]{1,5})?(/[^/]*)*$'
    test $(curl -o /dev/null -s --head -w "%{http_code}" "${url}") -ge 400 && { echo "无法访问"; return; }
    curl -# -L --fail "${1}" -o "${dir}/$(basename ${1})"
    if [ "$(du -b ${dir}/$(basename ${1}) 2>/dev/null | awk '{print $1}')" -le "512" ]; then
		echo -e "$(date '+%Y-%m-%d %H:%M:%S')\e[1;31m - 【$(basename ${1})】下载失败\e[0m"
		exit
	fi
	echo -e "$(date '+%Y-%m-%d %H:%M:%S')\e[1;32m - 【$(basename ${1})】下载完成\e[0m"
}