Model="R6S"
PROFILE="friendlyarm_nanopi-r6s"
# 自定义所需安装的包列表
DIY_PACKAGES=""
DIY_PACKAGES="$DIY_PACKAGES luci-app-scriptrun luci-app-mddns"
DIY_PACKAGES="$DIY_PACKAGES luci-app-socat luci-i18n-socat-zh-cn"
DIY_PACKAGES="$DIY_PACKAGES luci-i18n-argon-config-zh-cn"
# DIY_PACKAGES="$DIY_PACKAGES luci-i18n-passwall-zh-cn"
# DIY_PACKAGES="$DIY_PACKAGES luci-i18n-homeproxy-zh-cn"
DIY_PACKAGES="$DIY_PACKAGES luci-app-openclash-ninja kmod-nft-tproxy"
DIY_PACKAGES="$DIY_PACKAGES luci-app-v2ray-server xray-core"

# 下载luci-app-openclash-ninja内核
if echo "${DIY_PACKAGES}" | grep -q "luci-app-openclash-ninja"; then
	echo "下载 luci-app-openclash-ninja内核"
	mkdir -pm 755 "$(pwd)/files/openclash/core/"
	core="https://raw.githubusercontent.com/kachetong1314/ninja-core/linux/ninja-linux-arm64.tar.gz"
	wget -q "${core}" -O "/tmp/clash_core.tar.gz" && \
	tar -xzOf /tmp/clash_core.tar.gz > "$(pwd)/files/etc/openclash/core/clash_meta" && \
	chmod -R 755 "$(pwd)/files/etc/openclash/core/" && \
	ls -lhS "$(pwd)/files/etc/openclash/core/" | awk '{print $9,$5}'
fi